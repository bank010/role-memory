# ---- 对话端点（角色扮演回复） ----
# 支持任意 OpenAI 兼容接口（OpenAI / DeepSeek / BytePlus Ark / 自建 vLLM 等）
# 留空 CHAT_API_KEY 则自动进入 mock 模式，记忆机制照样可视化，适合先看架构跑通
CHAT_API_KEY=your_chat_api_key
CHAT_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-4o-mini

# ---- 抽取/摘要端点（可与对话端点分开） ----
# 建议用更稳定/支持 JSON 模式的模型做抽取；留空则回退复用对话端点
EXTRACT_API_KEY=your_extract_api_key
EXTRACT_BASE_URL=https://api.deepseek.com/v1
EXTRACT_MODEL=deepseek-chat
# 官方 DeepSeek / OpenAI 支持原生 JSON 模式，开启可提升抽取稳定性；部分端点不支持请留 0
EXTRACT_JSON_MODE=1

# ---- 向量端点（Qwen3-Embedding via vLLM，多语言，直接 embed 原文无需翻译） ----
# 留空则降级为本地哈希向量（dim=256），功能完整但语义召回质量低
EMBED_API_KEY=vllm
EMBED_BASE_URL=https://your-vllm-host/v1
EMBED_MODEL=your_embedding_model_path
# 向量维度：Qwen3-Embedding-8B=4096，text-embedding-3-small=1536，本地哈希=256
EMBED_DIM=4096

# ---- Rerank 精排端点（Qwen3-Reranker via vLLM） ----
# 留空则关闭，检索退回纯向量+三维打分召回
RERANK_BASE_URL=https://your-vllm-host/v1
RERANK_MODEL=your_reranker_model_path
RERANK_API_KEY=vllm
# 精排延迟预算（毫秒）：超时立即降级回粗排顺序，保证读路径不被精排拖垮；0=不限制
RERANK_TIMEOUT_MS=300

# ---- 记忆参数 ----
WORKING_WINDOW=6          # 工作窗口保留最近多少轮原文
PROCESS_EVERY=5           # 每累计多少轮触发一次记忆压缩（后台异步，抽取/摘要并行跑）
RETRIEVE_TOP_K=4          # 情节记忆召回条数
RECENCY_DECAY=0.02        # 新近度指数衰减系数（按轮，越大越偏向最近）
RECENCY_TIME_DECAY=0.01   # 真实时间衰减系数（按天）：离开两周回来，旧记忆不再"鲜活如昨"
VERBATIM_CANDIDATES=64    # 逐字召回 KNN 候选条数（postgres 预筛，候选内做混合重排）
MAX_FACTS=150             # 画像条数上限：超限按 置信度×新近度 淘汰（核心身份字段不淘汰）
FACTS_INJECT_TOP_K=30     # 画像注入上限：超限按 与query相关性+置信度+新近度 选 top-K 注入
QUERY_AUGMENT_MAX_LEN=24  # 用户消息短于此长度时（指代场景），拼上一轮对话做检索增强

# ---- 开关 ----
NSFW_ENABLED=1            # 敏感画像/事件提取与注入总开关（1=开启，0=关闭）
NORMALIZE_ENABLED=0       # 翻译归一化兜底（保持 0：记忆用用户的语言原文存储+embed，不花翻译 token；
                          # 仅当 embedding 模型不支持多语言时才设 1）

# ---- 存储后端 ----
# sqlite（默认，零依赖）| postgres（生产级，pgvector+HNSW索引，异步连接池）
STORE_BACKEND=sqlite
# STORE_BACKEND=postgres 时填写连接串
PG_DSN=postgresql://memory:memory@localhost:5432/role_memory
# 异步连接池大小（多实例部署时按 实例数×池上限 规划 PG max_connections / PgBouncer）
PG_POOL_MIN=2
PG_POOL_MAX=20

# ---- Redis 热缓存（留空=关闭，自动降级直查后端，绝不成为故障点） ----
# 启用后同时获得：facts/relationship 热读缓存、查询 embedding 缓存、
# 跨实例的记忆加工分布式锁（多 worker 部署强烈建议开启）
# REDIS_URL=redis://localhost:6379/0
CACHE_TTL=600
EMBED_CACHE_TTL=3600      # 查询 embedding 缓存 TTL（重复问法免一次远程 embed 调用）

# ---- MongoDB 对话归档（留空=关闭，自动降级 no-op，不影响对话） ----
# 与核心记忆解耦的"对话流水 + 训练数据湖"：每轮异步落一份完整 prompt（含注入记忆）+ 回复 + 元信息，
# 供后续偏好训练（点赞/点踩/重新生成）和外部系统集成读取。
# MONGO_URL=mongodb://localhost:27017
MONGO_DB=role_memory
MONGO_ARCHIVE_COLLECTION=conversations
MONGO_MAX_POOL=100
MONGO_TIMEOUT_MS=3000     # 连不上时快速失败并降级（毫秒）

# ---- CORS（前后端分离时配置前端域名白名单，留空=放行所有） ----
# CORS_ORIGINS=https://app.yourdomain.com,http://localhost:3000
