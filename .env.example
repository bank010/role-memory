# 不填 key 也能跑：自动进入 mock 模式（规则抽取 + 模板回复），记忆机制照样可视化。
# 想看真实效果，填一个 OpenAI 兼容的服务即可（OpenAI / 自建 vLLM / 任意兼容网关）。

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-4o-mini
# 抽取/反思用便宜小模型即可
EXTRACT_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small

# 记忆参数
WORKING_WINDOW=6          # 工作窗口保留最近多少轮原文
PROCESS_EVERY=3           # 每累计多少轮触发一次记忆加工
RETRIEVE_TOP_K=4          # 情节记忆召回条数
RECENCY_DECAY=0.02        # 新近度指数衰减系数（越大越偏向最近）

# ---- 存储后端 ----
# sqlite（默认，零依赖）| postgres（生产级，pgvector）
STORE_BACKEND=sqlite
# STORE_BACKEND=postgres 时连接串：
PG_DSN=postgresql://localhost:5432/role_memory
# EMBED_DIM=256          # 向量维度；本地哈希=256，真实 embedding=1536（建 pgvector 列用）

# ---- Redis 热缓存（留空=关闭，自动降级直查）----
# REDIS_URL=redis://localhost:6379/0
CACHE_TTL=600
